---
import Sidebar from "../components/Sidebar.astro";
import { navItems } from "../components/sidebarData";

const { title = "Site" } = Astro.props;
const currentPath = Astro.url.pathname;
---

<html lang="ja">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <title>{title}</title>
  </head>
  <body>
    <div class="shell">
      <aside class="sidebar">
        <div class="sidebar-header">Verilog-HDL Notebook</div>
        <Sidebar items={navItems} currentPath={currentPath} />
      </aside>

      <div class="content">
        <header class="topbar">{title}</header>
        <main class="main">
          <slot />
        </main>
      </div>
    </div>
  </body>
</html>

<style>
  :root {
    --sidebar-width: 270px;
    --border: #d8dee4;
    --sidebar-bg: #f8fafc;
    --text: #1f2937;
  }

  html,
  body {
    margin: 0;
    padding: 0;
    color: var(--text);
    font-family: system-ui, sans-serif;
  }

  .shell {
    display: grid;
    grid-template-columns: var(--sidebar-width) 1fr;
    min-height: 100vh;
  }

  .sidebar {
    background: var(--sidebar-bg);
    border-right: 1px solid var(--border);
    padding: 1rem;
    overflow-y: auto;
  }

  .sidebar-header {
    font-size: 1.1rem;
    font-weight: 700;
    margin-bottom: 1rem;
  }

  .content {
    min-width: 0;
  }

  .topbar {
    height: 56px;
    display: flex;
    align-items: center;
    padding: 0 1rem;
    border-bottom: 1px solid var(--border);
    font-weight: 600;
    background: white;
    position: sticky;
    top: 0;
  }

  .main {
    padding: 1.5rem;
    max-width: 1000px;
  }

  @media (max-width: 900px) {
    .shell {
      grid-template-columns: 1fr;
    }

    .sidebar {
      border-right: none;
      border-bottom: 1px solid var(--border);
    }
  }
</style>