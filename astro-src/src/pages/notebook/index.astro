---
import MainLayout from '../../layouts/MainLayout.astro';
const links = [
  { label: "Open Itのチュートリアル", href: "/notebook/open-it", external: false }
];
---

<MainLayout title="Home">
  <h2>練習ノートブック</h2>
  <p>
    Verilog-HDLの学習のための練習ノートブックです。
    <br>
    いろいろなサンプルコードを動かしてみて、挙動を確かめてみます。
    <br>

  <ul>
    {links.map((link) => (
      <li>
        <a
          href={link.href}
          target={link.external ? "_blank" : undefined}
          rel={link.external ? "noreferrer" : undefined}
        >
          {link.label}
        </a>
      </li>
    ))}
  </ul>

  </p>
</MainLayout>
