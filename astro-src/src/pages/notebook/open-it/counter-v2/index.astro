---
import MainLayout from '../../../../layouts/MainLayout.astro';
const embedBase = '/open-it/9648c728c319e0a9/';
---

<MainLayout title="Counter v2">
  <article class="Counter v2">
    <div id="observablehq-main"></div>
  </article>

  <link rel="stylesheet" href={`${embedBase}inspector.css`} />

  <script type="module">
    import define from "/open-it/9648c728c319e0a9/index.js";
    import { Runtime, Library, Inspector } from "/open-it/9648c728c319e0a9/runtime.js";

    const runtime = new Runtime();
    runtime.module(define, Inspector.into(document.querySelector("#observablehq-main")));
  </script>
</MainLayout>

<style>
  .embedded-html {
    width: 100%;
  }
</style>
