---
import MainLayout from '../../../../layouts/MainLayout.astro';
const embedBase = '/open-it/2e10889c4f56cf0f/';
---

<MainLayout title="D-Flip-Flop">
  <article class="D-Flip-Flop">
    <div id="observablehq-main"></div>
  </article>

  <link rel="stylesheet" href={`${embedBase}inspector.css`} />

  <script type="module">
    import define from "/open-it/2e10889c4f56cf0f/index.js";
    import { Runtime, Library, Inspector } from "/open-it/2e10889c4f56cf0f/runtime.js";

    const runtime = new Runtime();
    runtime.module(define, Inspector.into(document.querySelector("#observablehq-main")));
  </script>
</MainLayout>

<style>
  .embedded-html {
    width: 100%;
  }
</style>
