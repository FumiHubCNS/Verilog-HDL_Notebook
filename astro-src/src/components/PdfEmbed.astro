---
interface Props {
  src: string;
  title?: string;
  height?: string;
  zoom?: string;
}

const {
  src,
  title = 'PDF Viewer',
  height = '100dvh',
  zoom = 'page-width',
} = Astro.props;

const base = import.meta.env.BASE_URL;
const normalizedSrc = src.startsWith('/') ? src.slice(1) : src;
const fullSrc = `${base}${normalizedSrc}`;
const viewerUrl = `${base}pdfjs/web/viewer.html?file=${encodeURIComponent(fullSrc)}#zoom=${encodeURIComponent(zoom)}`;
---

<div class="pdf-wrap" style={`height:${height};`}>
  <iframe
    src={viewerUrl}
    title={title}
    class="pdf-frame"
  />
</div>

<style>
  .pdf-wrap {
    width: 100%;
  }

  .pdf-frame {
    width: 100%;
    height: 100%;
    display: block;
    border: 1px solid #ddd;
    border-radius: 8px;
  }
</style>